# ─────────────────────────────────────────
#  Tech Odyssey Magazine — Environment Config
#  COPY this file to .env and fill in values
#  NEVER commit .env to version control
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# JWT — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# PostgreSQL (Relational DB — Users, Sessions, Audit Logs)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=magazine_db
PG_USER=postgres
PG_PASSWORD=your_pg_password

# MongoDB (Document DB — Articles, AI outputs, Templates)
MONGO_URI=mongodb://localhost:27017/magazine_content

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# AI API (Optional — for real AI integration)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
